# GEMINI_API_KEY: Required for Gemini AI API calls (server-side only).
# This key is used by the /api/analyze route and is NEVER exposed to the browser.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# NEXT_PUBLIC_SUPABASE_URL: Supabase project URL (for feedback storage).
NEXT_PUBLIC_SUPABASE_URL="MY_SUPABASE_URL"

# NEXT_PUBLIC_SUPABASE_ANON_KEY: Supabase anonymous/public key.
NEXT_PUBLIC_SUPABASE_ANON_KEY="MY_SUPABASE_ANON_KEY"
